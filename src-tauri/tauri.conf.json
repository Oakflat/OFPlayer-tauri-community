{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OFPlayer Community",
  "version": "26.0.3",
  "identifier": "org.ofplayer.community",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "OFPlayer",
        "width": 1440,
        "height": 900,
        "minWidth": 1160,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/ofplayer/track-artwork/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp",
        "languages": ["English", "SimpChinese"],
        "customLanguageFiles": {
          "English": "installer/nsis/English.nsh",
          "SimpChinese": "installer/nsis/SimpChinese.nsh"
        },
        "installerHooks": "installer/nsis-hooks.nsh",
        "displayLanguageSelector": true,
        "installMode": "currentUser"
      },
      "wix": {
        "bannerPath": "installer/wix-banner.bmp",
        "dialogImagePath": "installer/wix-dialog.bmp",
        "language": {
          "en-US": {
            "localePath": "installer/wix/en-US.wxl"
          },
          "zh-CN": {
            "localePath": "installer/wix/zh-CN.wxl"
          }
        }
      }
    }
  }
}
